# Cabinet3D Editor 后端环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# 服务器配置
HOST=0.0.0.0
PORT=8001

# 数据库配置
# 默认使用 SQLite，文件保存在 backend 目录下
DATABASE_URL=sqlite+aiosqlite:///./cabinet.db

# LLM 配置
# 支持的模型格式: provider:model-name
# 示例:
#   - deepseek:deepseek-chat
#   - openai:gpt-4
#   - anthropic:claude-3-opus
#   - glm-5.1 (智谱)
LLM_MODEL=deepseek:deepseek-chat

# LLM API Key
# 从对应平台获取:
#   - DeepSeek: https://platform.deepseek.com/
#   - OpenAI: https://platform.openai.com/
#   - Anthropic: https://console.anthropic.com/
LLM_API_KEY=your-api-key-here

# LLM API Base URL (可选)
# 仅在使用自定义代理或私有部署时需要配置
# 示例:
#   - DeepSeek: https://api.deepseek.com
#   - OpenAI: https://api.openai.com/v1
#   - 智谱: https://open.bigmodel.cn/api/paas/v4
# LLM_BASE_URL=

# Skills 目录路径
# 指向包含 SKILL.md 文件的目录
SKILLS_DIR=./agent/skills/

# 干涉检查配置
# 是否在编辑后自动检查组件干涉（重叠）
# 设为 true 启用干涉检查，设为 false 禁用
ENABLE_INTERFERENCE_CHECK=true
